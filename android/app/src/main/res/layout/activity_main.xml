<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ── 顶部栏 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:text="clipd"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tvVersion"
            android:text="v1.0"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnSettings"
            android:text="⚙"
            android:textSize="18sp"
            android:background="@null"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:padding="0dp"/>
    </LinearLayout>

    <!-- ── 状态卡片 ── -->
    <LinearLayout
        android:id="@+id/cardStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="14dp" android:paddingBottom="14dp"
        android:background="@drawable/status_bg_idle">

        <!-- 状态指示点 / 搜索动画 -->
        <FrameLayout
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="10dp">

            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:background="@drawable/dot_gray"/>

            <ProgressBar
                android:id="@+id/pbSearching"
                style="?android:attr/progressBarStyle"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStatus"
                android:text="未运行"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvStatusSub"
                android:text="点击「开始同步」启动服务"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── 辅助功能行 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:background="@drawable/card_bg">

        <TextView
            android:id="@+id/tvAccessibility"
            android:text="检查辅助功能..."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnAccessibility"
            android:text="前往开启"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:background="@null"
            android:paddingStart="8dp" android:paddingEnd="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ── 通知镜像卡片 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:background="@drawable/card_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvNotifStatus"
                android:text="通知镜像 Android→Ubuntu"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnNotifAccess"
                android:text="前往授权"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:background="@null"
                android:paddingStart="8dp" android:paddingEnd="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:text="启用转发"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <Switch
                android:id="@+id/switchNotifMirror"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnPickApps"
                android:text="选择应用"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:background="@null"
                android:paddingStart="12dp" android:paddingEnd="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── 主操作按钮 ── -->
    <Button
        android:id="@+id/btnToggle"
        android:text="开始同步"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:background="@drawable/btn_primary_bg"
        android:paddingTop="14dp" android:paddingBottom="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- ── 日志入口 ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="8dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:background="@drawable/card_bg">

        <TextView
            android:id="@+id/tvLogBadge"
            android:text="日志"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnShowLog"
            android:text="查看"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:background="@null"
            android:paddingStart="8dp" android:paddingEnd="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>
