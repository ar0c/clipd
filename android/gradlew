#!/bin/sh
#
# Gradle start up script for POSIX compatible shells (sh, dash, ksh, zsh).
#

# Resolve the script's location to find project root
APP_HOME=$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")

# Determine JAVA_HOME / java command
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# Wrapper JAR and properties
WRAPPER_JAR="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_PROPERTIES="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"

exec "$JAVACMD" \
    ${JAVA_OPTS:-} \
    ${GRADLE_OPTS:-} \
    "-Dorg.gradle.appname=$(basename "$0")" \
    -classpath "$WRAPPER_JAR" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
